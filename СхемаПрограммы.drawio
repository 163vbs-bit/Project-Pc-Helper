<mxfile host="app.diagrams.net">
  <diagram name="Пользовательский интерфейс" id="ui-v2-extended">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ui_title" value="Расширенная пользовательская блок-схема версии 1.0" style="text;html=1;fontSize=26;fontStyle=1;strokeColor=none;fillColor=none" vertex="1" parent="1"><mxGeometry x="430" y="30" width="760" height="50" as="geometry"/></mxCell>
        <mxCell id="ui_start" value="Пользователь запускает приложение&#xa;2пр.py или 2пр.exe" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1" vertex="1" parent="1"><mxGeometry x="650" y="100" width="300" height="80" as="geometry"/></mxCell>
        <mxCell id="ui_window" value="Открывается окно Tkinter&#xa;title: Панель управления&#xa;geometry: 400 x 400&#xa;resizable: False, False" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15" vertex="1" parent="1"><mxGeometry x="610" y="230" width="380" height="120" as="geometry"/></mxCell>
        <mxCell id="ui_header" value="Пользователь видит заголовок&#xa;Управление компьютером" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15" vertex="1" parent="1"><mxGeometry x="180" y="420" width="280" height="80" as="geometry"/></mxCell>
        <mxCell id="ui_buttons" value="Пользователь выбирает действие&#xa;одна из 6 кнопок" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="690" y="390" width="220" height="150" as="geometry"/></mxCell>
        <mxCell id="ui_status" value="Строка состояния снизу окна&#xa;Выберите действие" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=15" vertex="1" parent="1"><mxGeometry x="1140" y="420" width="280" height="80" as="geometry"/></mxCell>
        <mxCell id="ui_browser" value="Кнопка: Открыть браузер&#xa;Результат: открывается Google&#xa;https://google.com" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="70" y="650" width="220" height="95" as="geometry"/></mxCell>
        <mxCell id="ui_youtube" value="Кнопка: Открыть YouTube&#xa;Результат: открывается YouTube&#xa;https://youtube.com" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1"><mxGeometry x="330" y="650" width="230" height="95" as="geometry"/></mxCell>
        <mxCell id="ui_explorer" value="Кнопка: Открыть проводник&#xa;Результат: открывается текущая папка проекта" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="600" y="650" width="250" height="95" as="geometry"/></mxCell>
        <mxCell id="ui_restart" value="Кнопка: Перезагрузить компьютер&#xa;Появляется подтверждение&#xa;Да: перезагрузка через 5 секунд&#xa;Нет: возврат к окну" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14" vertex="1" parent="1"><mxGeometry x="890" y="630" width="260" height="135" as="geometry"/></mxCell>
        <mxCell id="ui_shutdown" value="Кнопка: Выключить компьютер&#xa;Появляется подтверждение&#xa;Да: выключение через 5 секунд&#xa;Нет: возврат к окну" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1"><mxGeometry x="1190" y="630" width="260" height="135" as="geometry"/></mxCell>
        <mxCell id="ui_exit" value="Кнопка: Выход&#xa;Окно закрывается&#xa;приложение завершает работу" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1"><mxGeometry x="680" y="840" width="240" height="100" as="geometry"/></mxCell>
        <mxCell id="ui_rights" value="Важное условие&#xa;Для выключения и перезагрузки могут потребоваться права администратора. При ошибке пользователь увидит сообщение." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1010" y="860" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="ui_end" value="Конец выбранного действия&#xa;или ожидание следующего нажатия" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="650" y="1010" width="300" height="80" as="geometry"/></mxCell>
        <mxCell id="uie1" edge="1" parent="1" source="ui_start" target="ui_window" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie2" edge="1" parent="1" source="ui_window" target="ui_buttons" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie3" edge="1" parent="1" source="ui_window" target="ui_header" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie4" edge="1" parent="1" source="ui_window" target="ui_status" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie5" edge="1" parent="1" source="ui_buttons" target="ui_browser" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie6" edge="1" parent="1" source="ui_buttons" target="ui_youtube" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie7" edge="1" parent="1" source="ui_buttons" target="ui_explorer" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie8" edge="1" parent="1" source="ui_buttons" target="ui_restart" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie9" edge="1" parent="1" source="ui_buttons" target="ui_shutdown" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie10" edge="1" parent="1" source="ui_buttons" target="ui_exit" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie11" edge="1" parent="1" source="ui_restart" target="ui_rights" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie12" edge="1" parent="1" source="ui_shutdown" target="ui_rights" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie13" edge="1" parent="1" source="ui_browser" target="ui_end" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie14" edge="1" parent="1" source="ui_youtube" target="ui_end" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie15" edge="1" parent="1" source="ui_explorer" target="ui_end" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie16" edge="1" parent="1" source="ui_exit" target="ui_end" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uie17" edge="1" parent="1" source="ui_rights" target="ui_end" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Внутренняя логика" id="logic-v2-extended">
    <mxGraphModel dx="2200" dy="2600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1850" pageHeight="2550" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="l_title" value="Расширенная внутренняя блок-схема программы 2пр.py" style="text;html=1;fontSize=26;fontStyle=1;strokeColor=none;fillColor=none" vertex="1" parent="1"><mxGeometry x="500" y="30" width="850" height="50" as="geometry"/></mxCell>
        <mxCell id="l_start" value="Старт программы&#xa;запуск 2пр.py" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1" vertex="1" parent="1"><mxGeometry x="775" y="100" width="300" height="80" as="geometry"/></mxCell>
        <mxCell id="l_imports" value="Импорт библиотек&#xa;import tkinter as tk&#xa;from tkinter import messagebox&#xa;import webbrowser&#xa;import os&#xa;import platform&#xa;import subprocess" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="720" y="230" width="410" height="160" as="geometry"/></mxCell>
        <mxCell id="l_defs" value="Объявление функций-обработчиков&#xa;функции создаются до построения интерфейса" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="720" y="440" width="410" height="90" as="geometry"/></mxCell>
        <mxCell id="l_f_browser" value="open_browser()&#xa;webbrowser.open(&quot;https://google.com&quot;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="1"><mxGeometry x="80" y="600" width="250" height="85" as="geometry"/></mxCell>
        <mxCell id="l_f_youtube" value="open_youtube()&#xa;webbrowser.open(&quot;https://youtube.com&quot;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="1"><mxGeometry x="370" y="600" width="260" height="85" as="geometry"/></mxCell>
        <mxCell id="l_f_explorer" value="open_explorer()&#xa;system = platform.system()&#xa;выбор команды открытия папки" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13" vertex="1" parent="1"><mxGeometry x="670" y="590" width="280" height="105" as="geometry"/></mxCell>
        <mxCell id="l_f_restart" value="restart_computer()&#xa;messagebox.askyesno()&#xa;после подтверждения выбирается команда ОС" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13" vertex="1" parent="1"><mxGeometry x="990" y="585" width="300" height="115" as="geometry"/></mxCell>
        <mxCell id="l_f_shutdown" value="shutdown_computer()&#xa;messagebox.askyesno()&#xa;после подтверждения выбирается команда ОС" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="1"><mxGeometry x="1330" y="585" width="300" height="115" as="geometry"/></mxCell>
        <mxCell id="l_f_exit" value="exit_app()&#xa;root.destroy()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="1"><mxGeometry x="780" y="750" width="290" height="80" as="geometry"/></mxCell>
        <mxCell id="l_ui_root" value="Создание главного окна&#xa;root = tk.Tk()&#xa;root.title(&quot;Панель управления&quot;)&#xa;root.geometry(&quot;400x400&quot;)&#xa;root.resizable(False, False)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="720" y="900" width="410" height="140" as="geometry"/></mxCell>
        <mxCell id="l_style" value="Настройка стиля кнопок&#xa;button_style: font, width, height, bd, relief" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=14" vertex="1" parent="1"><mxGeometry x="720" y="1090" width="410" height="85" as="geometry"/></mxCell>
        <mxCell id="l_label" value="Создание заголовка&#xa;tk.Label(..., text=&quot;Управление компьютером&quot;)&#xa;title_label.pack()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1"><mxGeometry x="720" y="1230" width="410" height="105" as="geometry"/></mxCell>
        <mxCell id="l_buttons" value="Создание кнопок tk.Button&#xa;каждая кнопка получает text, command, bg, fg и button_style" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="720" y="1390" width="410" height="100" as="geometry"/></mxCell>
        <mxCell id="l_btn_browser" value="btn_browser&#xa;command=open_browser&#xa;pack(pady=5)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="1"><mxGeometry x="80" y="1570" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="l_btn_youtube" value="btn_youtube&#xa;command=open_youtube&#xa;pack(pady=5)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="1"><mxGeometry x="350" y="1570" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="l_btn_explorer" value="btn_explorer&#xa;command=open_explorer&#xa;pack(pady=5)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13" vertex="1" parent="1"><mxGeometry x="620" y="1570" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="l_btn_restart" value="btn_restart&#xa;command=restart_computer&#xa;pack(pady=5)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13" vertex="1" parent="1"><mxGeometry x="890" y="1570" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="l_btn_shutdown" value="btn_shutdown&#xa;command=shutdown_computer&#xa;pack(pady=5)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="1"><mxGeometry x="1170" y="1570" width="250" height="90" as="geometry"/></mxCell>
        <mxCell id="l_btn_exit" value="btn_exit&#xa;command=exit_app&#xa;pack(pady=20)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="1"><mxGeometry x="1460" y="1570" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="l_status" value="Создание статусной строки&#xa;status_label = tk.Label(...)&#xa;pack(side=&quot;bottom&quot;, fill=&quot;x&quot;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=14" vertex="1" parent="1"><mxGeometry x="720" y="1730" width="410" height="105" as="geometry"/></mxCell>
        <mxCell id="l_mainloop" value="Запуск цикла событий&#xa;root.mainloop()&#xa;программа ждёт нажатий пользователя" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="755" y="1900" width="340" height="95" as="geometry"/></mxCell>
        <mxCell id="l_event" value="Событие: пользователь нажал кнопку" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="775" y="2040" width="300" height="90" as="geometry"/></mxCell>
        <mxCell id="l_web_action" value="Вызов webbrowser.open(url)&#xa;передача ссылки браузеру по умолчанию" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="1"><mxGeometry x="80" y="1845" width="270" height="95" as="geometry"/></mxCell>
        <mxCell id="l_explorer_os" value="open_explorer(): выбор ОС&#xa;Windows: os.startfile(&quot;.&quot;)&#xa;macOS: subprocess.run([&quot;open&quot;, &quot;.&quot;])&#xa;Linux: subprocess.run([&quot;xdg-open&quot;, &quot;.&quot;])" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13" vertex="1" parent="1"><mxGeometry x="390" y="1815" width="310" height="145" as="geometry"/></mxCell>
        <mxCell id="l_confirm" value="Для restart/shutdown: подтверждение&#xa;messagebox.askyesno(&quot;Подтверждение&quot;, ...)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13" vertex="1" parent="1"><mxGeometry x="1180" y="1810" width="290" height="150" as="geometry"/></mxCell>
        <mxCell id="l_cancel" value="Если пользователь нажал Нет&#xa;команда не выполняется&#xa;возврат к mainloop" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=13" vertex="1" parent="1"><mxGeometry x="1510" y="1815" width="270" height="105" as="geometry"/></mxCell>
        <mxCell id="l_try" value="Если нажато Да&#xa;try: определить ОС и выполнить системную команду" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13" vertex="1" parent="1"><mxGeometry x="1180" y="2005" width="290" height="95" as="geometry"/></mxCell>
        <mxCell id="l_restart_cmd" value="Перезагрузка&#xa;Windows: os.system(&quot;shutdown /r /t 5&quot;)&#xa;macOS/Linux: sudo shutdown -r now&#xa;showinfo: перезагрузка через 5 секунд" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13" vertex="1" parent="1"><mxGeometry x="850" y="2200" width="390" height="135" as="geometry"/></mxCell>
        <mxCell id="l_shutdown_cmd" value="Выключение&#xa;Windows: os.system(&quot;shutdown /s /t 5&quot;)&#xa;macOS/Linux: sudo shutdown -h now&#xa;showinfo: выключение через 5 секунд" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="1"><mxGeometry x="1290" y="2200" width="390" height="135" as="geometry"/></mxCell>
        <mxCell id="l_except" value="except Exception as e&#xa;messagebox.showerror(&quot;Ошибка&quot;, ...)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="1"><mxGeometry x="1080" y="2390" width="340" height="95" as="geometry"/></mxCell>
        <mxCell id="l_exit_action" value="Выход из приложения&#xa;root.destroy() закрывает окно&#xa;mainloop завершается" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="1"><mxGeometry x="1480" y="2025" width="280" height="95" as="geometry"/></mxCell>
        <mxCell id="l_return" value="После действия&#xa;приложение остаётся открытым&#xa;и снова ждёт событие&#xa;кроме кнопки Выход" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="745" y="2400" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="le1" edge="1" parent="1" source="l_start" target="l_imports" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le2" edge="1" parent="1" source="l_imports" target="l_defs" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le3" edge="1" parent="1" source="l_defs" target="l_f_browser" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le4" edge="1" parent="1" source="l_defs" target="l_f_youtube" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le5" edge="1" parent="1" source="l_defs" target="l_f_explorer" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le6" edge="1" parent="1" source="l_defs" target="l_f_restart" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le7" edge="1" parent="1" source="l_defs" target="l_f_shutdown" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le8" edge="1" parent="1" source="l_defs" target="l_f_exit" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le9" edge="1" parent="1" source="l_defs" target="l_ui_root" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le10" edge="1" parent="1" source="l_ui_root" target="l_style" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le11" edge="1" parent="1" source="l_style" target="l_label" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le12" edge="1" parent="1" source="l_label" target="l_buttons" style="endArrow=block;html=1;rounded=0"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le13" edge="1" parent="1" source="l_buttons" target="l_btn_browser" style="endArrow=block;html=1;rounded=1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="3" value="Главное окно Tkinter&#xa;System Control Panel&#xa;800 x 500, темная тема" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1" vertex="1" parent="1"><mxGeometry x="390" y="90" width="340" height="120" as="geometry"/></mxCell>
        <mxCell id="4" value="3 ряда кнопок" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16" vertex="1" parent="1"><mxGeometry x="470" y="250" width="180" height="120" as="geometry"/></mxCell>
        <mxCell id="5" value="Основные действия&#xa;Google, YouTube, проводник" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="80" y="450" width="250" height="70" as="geometry"/></mxCell>

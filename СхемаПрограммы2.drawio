        <mxCell id="7" value="Дополнительные действия&#xa;блокнот, калькулятор, GitHub" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1"><mxGeometry x="790" y="450" width="280" height="70" as="geometry"/></mxCell>
